OPENAI_API_KEY=your_openai_api_key_here

# Used to sign login tokens. Generate a real random value for production,
# e.g. run: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_to_a_random_string

# Defaults to a local SQLite file if not set. Point this at a Postgres URL in production,
# e.g. postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./smart_invoice.db